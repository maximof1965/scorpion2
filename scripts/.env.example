# Copia este archivo como .env (en la misma carpeta scripts/) y rellena con tus claves reales.
# IMPORTANTE: el archivo .env NO se sube a GitHub (esta en .gitignore).

# URL de tu proyecto Supabase (la encuentras en: Project Settings -> API -> Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Clave SERVICE_ROLE de Supabase (NO la anon)
# La encuentras en: Project Settings -> API -> Project API keys -> service_role (secret)
# Esta clave bypasea RLS y permite cargas masivas. NUNCA la compartas ni la subas a GitHub.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
